DEE_PUBLIC_HOST=dee.example.com
DEE_IMAGE=meiro-decision-engine:latest
DEE_PORT=8080
DEE_DATA_DIR=/app/data
DEE_DB_PATH=/app/data/dee.sqlite
DEE_AUDIT_RETENTION_DAYS=90
DEE_CLIENT_EVENT_RETENTION_DAYS=180
DEE_BOOTSTRAP_TOKENS_ENABLED=false
DEE_TOKENS=[]
DEE_REQUEST_BODY_LIMIT_BYTES=1048576
DEE_BATCH_REQUEST_BODY_LIMIT_BYTES=8388608
DEE_REQUEST_TIMEOUT_MS=15000
DEE_HEADERS_TIMEOUT_MS=16000
DEE_KEEP_ALIVE_TIMEOUT_MS=5000
DEE_MAX_REQUESTS_PER_SOCKET=1000
DEE_CLIENT_RATE_LIMIT_WINDOW_MS=60000
DEE_CLIENT_RATE_LIMIT_MAX=600

# Optional Meiro settings can also be configured in the UI after first admin login.
MEIRO_BASE_URL=https://sse-demo.eu1.pipes.meiro.io
